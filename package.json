{
  "name": "a12p-api-p1",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "esbuild src/lambda.ts --bundle --platform=node --target=node24 --external:pg-native --outfile=dist/index.js",
    "coverage": "vitest run --coverage",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "prepare": "husky",
    "db:seed:local": "tsx --env-file=.env scripts/run-seed.ts",
    "db:seed:prod": "node --env-file=.env.production ./node_modules/drizzle-kit/bin.cjs push && tsx --env-file=.env.production scripts/run-seed.ts",
    "test": "vitest run",
    "up": "docker compose up -d"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.25",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
